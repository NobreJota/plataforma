<div class="coop-menu-wrap">

  {{!-- Sidebar principal --}}
  <nav class="coop-sidebar">
    <div class="coop-sidebar-header">
      <i class="ti ti-building-store" aria-hidden="true"></i>
      <span>Cooperado</span>
    </div>

    <ul class="coop-nav">
      <li class="coop-nav-item {{#if (eq activeMenu 'fluxo')}}active{{/if}}"
          data-menu="fluxo">
        <i class="ti ti-cash" aria-hidden="true"></i>
        <span>Fluxo de Caixa</span>
        <i class="ti ti-chevron-right coop-arrow" aria-hidden="true"></i>
      </li>
      <li class="coop-nav-item {{#if (eq activeMenu 'contabil')}}active{{/if}}"
          data-menu="contabil">
        <i class="ti ti-calculator" aria-hidden="true"></i>
        <span>Contabilidade</span>
        <i class="ti ti-chevron-right coop-arrow" aria-hidden="true"></i>
      </li>
      <li class="coop-nav-item {{#if (eq activeMenu 'compra')}}active{{/if}}"
          data-menu="compra">
        <i class="ti ti-shopping-cart" aria-hidden="true"></i>
        <span>Compra</span>
        <i class="ti ti-chevron-right coop-arrow" aria-hidden="true"></i>
      </li>
      <li class="coop-nav-item {{#if (eq activeMenu 'venda')}}active{{/if}}"
          data-menu="venda">
        <i class="ti ti-tag" aria-hidden="true"></i>
        <span>Venda</span>
        <i class="ti ti-chevron-right coop-arrow" aria-hidden="true"></i>
      </li>
      <li class="coop-nav-item {{#if (eq activeMenu 'site')}}active{{/if}}"
          data-menu="site">
        <i class="ti ti-world" aria-hidden="true"></i>
        <span>Site</span>
      </li>
    </ul>
  </nav>

  {{!-- Coluna de submenus (nível 2) --}}
  <div class="coop-sub-col" id="coop-sub-panel">

    {{!-- Fluxo de Caixa --}}
    <ul class="coop-sub-list" data-sub="fluxo">
      <li class="coop-sub-title">Fluxo de Caixa</li>
      <li class="coop-sub-item" data-url="/financeiro/fluxo">
        <span>Grid mês a mês</span>
      </li>
      <li class="coop-sub-item" data-url="/financeiro/orcamento">
        <span>Orçamento Anual</span>
      </li>
    </ul>

    {{!-- Contabilidade --}}
    <ul class="coop-sub-list" data-sub="contabil">
      <li class="coop-sub-title">Contabilidade</li>
     <li class="coop-sub-item" data-url="/contab/plano">
  <span>Plano de contas</span>
</li>
      <li class="coop-sub-item" data-url="/contab/razao">
        <span>Razão</span>
      </li>
      <li class="coop-sub-item" data-leaf="pessoal" data-url="/contabil/pessoal">
        <span>Pessoal</span><i class="ti ti-chevron-right" aria-hidden="true"></i>
      </li>
      <li class="coop-sub-item" data-url="/contabil/relatorios">
        <span>Relatórios</span>
      </li>
    </ul>

    {{!-- Compra --}}
    <ul class="coop-sub-list" data-sub="compra">
      <li class="coop-sub-title">Compra</li>
      <li class="coop-sub-item" data-url="/aux/fornecedores">
        <span>Fornecedores</span>
      </li>
      <li class="coop-sub-item" data-url="/compra/pedidos">
        <span>Pedidos</span>
      </li>
      <li class="coop-sub-item" data-url="/compra/entrada">
        <span>Entrada de mercadoria</span>
      </li>
      <li class="coop-sub-item" data-url="/compra/relatorios">
        <span>Relatórios</span>
      </li>
    </ul>

    {{!-- Venda --}}
    <ul class="coop-sub-list" data-sub="venda">
      <li class="coop-sub-title">Venda</li>
      <li class="coop-sub-item" data-url="/aux/clientes">
        <span>Clientes</span>
      </li>
      <li class="coop-sub-item" data-url="/venda/notas-fiscais">
        <span>Notas fiscais</span>
      </li>
      <li class="coop-sub-item" data-url="/venda/relatorios">
        <span>Relatórios</span>
      </li>
    </ul>

    {{!-- Site --}}
    <ul class="coop-sub-list" data-sub="site">
      <li class="coop-sub-title">Site</li>
      <li class="coop-sub-item" data-url="/site/configuracoes">
