<div class="orc-page">
  <header class="orc-header">
    <h1>📊 Orçamento Anual</h1>
    <div class="orc-controls">
      <label class="orc-ano-label">
        Ano:
        <select id="combo-ano" class="orc-ano-select"></select>
      </label>
      <button class="orc-btn-vincular" id="btn-vincular">🔗 Vincular contas</button>
    </div>
  </header>

  <div class="orc-grid-wrap">
    <table class="orc-grid" id="grid">
      <thead>
        <tr id="grid-head">
          <th class="col-item">#</th>
          <th class="col-conta">Contas</th>
          <th>Jan</th><th>Fev</th><th>Mar</th><th>Abr</th><th>Mai</th><th>Jun</th>
          <th>Jul</th><th>Ago</th><th>Set</th><th>Out</th><th>Nov</th><th>Dez</th>
        </tr>
      </thead>
      <tbody id="grid-body">
        <tr><td colspan="14" class="orc-empty">Carregando...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal vincular contas -->
<div id="modal-vincular" class="orc-modal" hidden>
  <div class="orc-modal-content">
    <div class="orc-modal-header">
      <h2>🔗 Vincular contas ao orçamento</h2>
      <button class="orc-close" id="btn-fechar-vincular">×</button>
    </div>
    <div class="orc-modal-body">
      <p class="orc-hint">Marque as contas de despesa (grupo 3) que entram na projeção.
        A vinculação vale para todos os anos. Desmarcar uma conta a desativa
        (ex: financiamento que acabou) sem apagar o histórico.</p>
      <input type="search" id="busca-contas" class="orc-busca" placeholder="🔍 Buscar conta...">
      <select id="filtro-titulo" class="orc-filtro-titulo">
        <option value="">Todos os títulos</option>
      </select>
      <div class="orc-lista-vincular" id="lista-vincular">
        <p class="orc-empty">Carregando contas...</p>
      </div>
    </div>
    <div class="orc-modal-footer">
      <span id="contador-vinc" class="orc-contador-vinc"></span>
      <button type="button" id="btn-cancelar-vincular" class="orc-btn-cancel">Cancelar</button>
      <button type="button" id="btn-salvar-vincular" class="orc-btn-salvar">Salvar vinculação</button>
    </div>
  </div>
</div>

<style>
  .orc-page { padding:20px; max-width:1400px; margin:0 auto; }
  .orc-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; flex-wrap:wrap; gap:12px; }
  .orc-header h1 { margin:0; font-size:1.5rem; }
  .orc-controls { display:flex; align-items:center; gap:14px; }
  .orc-ano-label { display:flex; align-items:center; gap:8px; font-weight:600; color:#374151; }
  .orc-ano-select { padding:8px 12px; border:1px solid #d1d5db; border-radius:7px; font-size:1rem; font-weight:600; }
  .orc-btn-vincular { background:#0891b2; color:#fff; border:none; border-radius:8px; padding:10px 18px; font-weight:600; cursor:pointer; }
  .orc-btn-vincular:hover { background:#0e7490; }

  /* Grid */
  .orc-grid-wrap { overflow-x:auto; border:1px solid #d1d5db; border-radius:8px; background:#fff; }
  .orc-grid { width:100%; border-collapse:collapse; font-size:.85rem; }
  .orc-grid th { background:#f3f4f6; color:#374151; padding:8px 10px; text-align:right; font-size:.75rem; border-bottom:2px solid #d1d5db; white-space:nowrap; position:sticky; top:0; }
  .orc-grid th.col-item { text-align:center; width:36px; }
  .orc-grid th.col-conta { text-align:left; min-width:220px; }
  .orc-grid td { padding:6px 10px; border-bottom:1px solid #f0f0f0; text-align:right; white-space:nowrap; }
  .orc-grid td.cel-item { text-align:center; color:#9ca3af; font-size:.75rem; }
  .orc-grid td.cel-conta { text-align:left; }

  /* Cabeçalho de grupo (ContaTítulo) — azul */
  .orc-grupo-row td { background:#eff6ff; color:#1d4ed8; font-weight:700; border-top:1px solid #bfdbfe; padding:8px 10px; }

  /* Linha de conta (SubTítulo) */
  .orc-conta-row:hover { background:#f9fafb; }
  .orc-conta-row .cel-conta { color:#1f2937; padding-left:20px; }

  /* Célula de valor */
  .cel-valor { cursor:pointer; font-variant-numeric:tabular-nums; }
  .cel-valor:hover { background:#dbeafe; border-radius:4px; }
  .cel-valor.tem-valor { color:#1d4ed8; font-weight:600; }
  .cel-valor.vazio { color:#d1d5db; }   /* ,00 suave */

  .orc-empty { text-align:center; padding:32px; color:#9ca3af; }

  /* Modal */
  .orc-modal { position:fixed; inset:0; background:rgba(0,0,0,.5); display:flex; align-items:center; justify-content:center; z-index:1000; }
  .orc-modal[hidden] { display:none; }
  .orc-modal-content { background:#fff; border-radius:12px; width:90%; max-width:640px; max-height:85vh; display:flex; flex-direction:column; }
  .orc-modal-header { display:flex; justify-content:space-between; align-items:center; padding:18px 20px; background:#0891b2; color:#fff; border-radius:12px 12px 0 0; }
  .orc-modal-header h2 { margin:0; font-size:1.15rem; }
  .orc-close { background:none; border:none; color:#fff; font-size:1.6rem; cursor:pointer; }
  .orc-modal-body { padding:18px 20px; overflow-y:auto; flex:1; }
  .orc-hint { font-size:.82rem; color:#6b7280; margin:0 0 12px; line-height:1.4; }
  .orc-busca { width:100%; padding:9px 12px; border:1px solid #d1d5db; border-radius:7px; margin-bottom:8px; box-sizing:border-box; }
  .orc-filtro-titulo { width:100%; padding:9px 12px; border:1px solid #d1d5db; border-radius:7px; margin-bottom:12px; box-sizing:border-box; font-size:.9rem; background:#f9fafb; }

  .orc-lista-vincular { display:flex; flex-direction:column; gap:2px; }
  .orc-grupo-vinc { font-weight:700; color:#0e7490; font-size:.8rem; margin:10px 0 4px; padding-bottom:3px; border-bottom:1px solid #e5e7eb; }
  .orc-item-vinc { display:flex; align-items:center; gap:10px; padding:7px 8px; border-radius:6px; cursor:pointer; }
  .orc-item-vinc:hover { background:#f0f9ff; }
  .orc-item-vinc input { width:17px; height:17px; cursor:pointer; }
  .orc-item-vinc .cod { font-family:monospace; font-size:.78rem; color:#6b7280; min-width:100px; }
  .orc-item-vinc .nm { font-size:.88rem; color:#1f2937; }

  .orc-modal-footer { display:flex; align-items:center; gap:12px; padding:14px 20px; border-top:1px solid #e5e7eb; }
  .orc-contador-vinc { flex:1; font-size:.82rem; color:#6b7280; }
  .orc-btn-cancel { background:#f3f4f6; border:1px solid #d1d5db; border-radius:7px; padding:9px 18px; cursor:pointer; font-weight:500; }
  .orc-btn-salvar { background:#0891b2; color:#fff; border:none; border-radius:7px; padding:9px 22px; font-weight:600; cursor:pointer; }
  .orc-btn-salvar:hover { background:#0e7490; }
</style>

<script src="/js/financeiro/orcamento.js"></script>
