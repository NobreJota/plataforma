<div class="for-page">
  <header class="for-header">
    <h1>🏭 Fornecedores</h1>
    <p class="for-subtitle">Cadastro unificado (compartilhado com o site)</p>
    <button class="for-btn-novo" id="btn-novo">+ Novo fornecedor</button>
  </header>

  <div class="for-toolbar">
    <input type="search" id="busca" class="for-input" placeholder="🔍 Buscar por razão, CNPJ ou marca...">
    <label class="for-checkbox">
      <input type="checkbox" id="incluir-inativos"> Incluir inativos
    </label>
    <span id="contador" class="for-contador">0 fornecedores</span>
  </div>

  <table class="for-table">
    <thead>
      <tr>
        <th>RAZÃO SOCIAL</th>
        <th>CNPJ / CPF</th>
        <th>MARCA</th>
        <th>CIDADE</th>
        <th>STATUS</th>
        <th>AÇÕES</th>
      </tr>
    </thead>
    <tbody id="lista-fornecedores">
      <tr><td colspan="6" class="for-empty">Carregando...</td></tr>
    </tbody>
  </table>
</div>

<!-- Modal -->
<div id="modal-fornecedor" class="for-modal" hidden>
  <div class="for-modal-content">
    <div class="for-modal-header">
      <h2 id="modal-titulo">Novo fornecedor</h2>
      <button class="for-close" id="btn-fechar">×</button>
    </div>

    <form id="form-fornecedor" class="for-form" autocomplete="off">

      <!-- Identificação -->
      <fieldset class="for-fieldset">
        <legend>📋 Identificação</legend>
        <div class="for-row">
          <label class="flex-fix" style="min-width:160px">
            <span>Tipo <em>*</em></span>
            <select id="f-tipo" tabindex="1" autocomplete="off">
              <option value="PJ">Pessoa Jurídica</option>
              <option value="PF">Pessoa Física</option>
            </select>
          </label>
          <label class="flex-fix" style="min-width:220px">
            <span id="label-doc">CNPJ <em>*</em></span>
            <div class="input-wrap">
              <input type="text" id="f-cpfCnpj" tabindex="2" required placeholder="00.000.000/0000-00"
                     autocomplete="off" autocorrect="off" spellcheck="false">
              <span class="status-busca" id="status-cnpj"></span>
            </div>
          </label>
        </div>
        <div class="for-row">
          <label class="flex-grow">
            <span>Razão social / Nome <em>*</em></span>
            <input type="text" id="f-nome" tabindex="3" required placeholder="Nome do fornecedor"
                   autocomplete="off" autocorrect="off" spellcheck="false">
          </label>
        </div>
        <div class="for-row">
          <label class="flex-fix" style="min-width:240px">
            <span>Marca</span>
            <input type="text" id="f-marca" tabindex="4" placeholder="Marca / fantasia" autocomplete="off">
          </label>
          <label class="flex-fix" style="min-width:200px">
            <span>Nº Contábil</span>
            <input type="text" id="f-ncontabil" tabindex="5" placeholder="Vínculo contábil" autocomplete="off">
          </label>
        </div>
      </fieldset>

      <!-- Inscrições (só PJ) -->
      <fieldset class="for-fieldset" id="bloco-inscricoes">
        <legend>🏢 Inscrições (PJ)</legend>
        <div class="bloco-inscricoes">
          <label class="flex-grow">
            <span>Inscrição Estadual</span>
            <div class="campo-isento-wrap">
              <input type="text" id="f-inscricaoEstadual" placeholder="Apenas números" autocomplete="off">
              <button type="button" class="btn-isento" data-target="f-inscricaoEstadual">ISENTO</button>
            </div>
          </label>
          <label class="flex-grow">
            <span>Inscrição Municipal</span>
            <div class="campo-isento-wrap">
              <input type="text" id="f-inscricaoMunicipal" placeholder="Apenas números" autocomplete="off">
              <button type="button" class="btn-isento" data-target="f-inscricaoMunicipal">ISENTO</button>
            </div>
          </label>
        </div>
      </fieldset>

      <!-- Contato principal -->
      <fieldset class="for-fieldset">
        <legend>📞 Contato principal</legend>
        <div class="for-row">
          <label class="flex-grow">
            <span>E-mail</span>
            <input type="email" id="f-email" tabindex="6" placeholder="exemplo@email.com" autocomplete="off">
          </label>
          <label class="flex-fix" style="min-width:200px">
            <span>Telefone</span>
            <input type="tel" id="f-telefone" tabindex="7" placeholder="(00) 00000-0000" autocomplete="off">
          </label>
        </div>
      </fieldset>

      <!-- Endereço -->
      <fieldset class="for-fieldset">
        <legend>📍 Endereço</legend>
        <div class="for-row">
          <label class="flex-fix" style="min-width:200px">
            <span>CEP</span>
            <div class="input-wrap">
              <input type="tel" id="cob-cep" tabindex="8" placeholder="00000-000" maxlength="9"
                     inputmode="numeric" autocomplete="off" autocorrect="off" spellcheck="false">
              <span class="status-busca" id="status-cep-cob"></span>
            </div>
          </label>
          <label class="flex-grow">
            <span>Logradouro</span>
            <input type="text" id="cob-logradouro" tabindex="9" placeholder="Rua, Avenida..." autocomplete="off">
          </label>
          <label class="flex-fix" style="min-width:100px">
            <span>Número</span>
            <input type="text" id="cob-numero" tabindex="10" placeholder="100" autocomplete="off">
          </label>
        </div>
        <div class="for-row">
          <label class="flex-fix" style="min-width:200px">
            <span>Complemento</span>
            <input type="text" id="cob-complemento" tabindex="11" placeholder="Sala, Apto..." autocomplete="off">
          </label>
          <label class="flex-grow">
            <span>Bairro</span>
            <input type="text" id="cob-bairro" tabindex="12" placeholder="Bairro" autocomplete="off">
          </label>
        </div>
        <div class="for-row">
          <label class="flex-grow">
            <span>Cidade</span>
            <input type="text" id="cob-cidade" tabindex="13" placeholder="Cidade" autocomplete="off">
          </label>
          <label class="flex-fix" style="min-width:90px">
            <span>UF</span>
            <input type="text" id="cob-uf" tabindex="14" maxlength="2" placeholder="ES" autocomplete="off">
          </label>
        </div>
      </fieldset>

      <!-- Contatos especializados (colapsável) -->
      <fieldset class="for-fieldset">
        <legend>
          <button type="button" class="toggle-contatos" id="toggle-contatos">
            👥 Contatos especializados <span id="seta-contatos">▼</span>
          </button>
        </legend>
        <div id="bloco-contatos" hidden>
          <div class="contato-grupo">
            <h4>Representante</h4>
            <div class="for-row">
              <label class="flex-grow"><span>Nome</span>
                <input type="text" id="rep-nome" autocomplete="off"></label>
              <label class="flex-grow"><span>E-mail</span>
                <input type="email" id="rep-email" autocomplete="off"></label>
              <label class="flex-fix" style="min-width:170px"><span>Celular</span>
                <input type="tel" id="rep-celular" autocomplete="off"></label>
            </div>
          </div>
          <div class="contato-grupo">
            <h4>Comercial</h4>
            <div class="for-row">
              <label class="flex-grow"><span>Nome</span>
                <input type="text" id="com-nome" autocomplete="off"></label>
              <label class="flex-grow"><span>E-mail</span>
                <input type="email" id="com-email" autocomplete="off"></label>
              <label class="flex-fix" style="min-width:170px"><span>Celular</span>
                <input type="tel" id="com-celular" autocomplete="off"></label>
            </div>
          </div>
          <div class="contato-grupo">
            <h4>Técnica</h4>
            <div class="for-row">
              <label class="flex-grow"><span>Nome</span>
                <input type="text" id="tec-nome" autocomplete="off"></label>
              <label class="flex-grow"><span>E-mail</span>
                <input type="email" id="tec-email" autocomplete="off"></label>
              <label class="flex-fix" style="min-width:170px"><span>Celular</span>
                <input type="tel" id="tec-celular" autocomplete="off"></label>
            </div>
          </div>
        </div>
      </fieldset>

      <div class="for-modal-footer">
        <button type="button" id="btn-cancelar" class="for-btn-cancel">Cancelar</button>
        <button type="submit" class="for-btn-salvar" id="btn-salvar">Salvar</button>
      </div>
    </form>
  </div>
</div>

<style>
  .for-page { padding:24px; max-width:1200px; margin:0 auto; }
  .for-header { display:flex; align-items:center; gap:16px; margin-bottom:8px; }
  .for-header h1 { margin:0; font-size:1.6rem; }
  .for-subtitle { color:#6b7280; font-size:.95rem; margin:0; flex:1; }
  .for-btn-novo { background:#7c3aed; color:#fff; border:none; border-radius:8px; padding:10px 18px; font-weight:600; cursor:pointer; }
  .for-btn-novo:hover { background:#6d28d9; }

  .for-toolbar { display:flex; align-items:center; gap:16px; margin:16px 0; padding:12px; background:#f9fafb; border-radius:8px; }
  .for-input { flex:1; padding:8px 12px; border:1px solid #d1d5db; border-radius:7px; font-size:.95rem; }
  .for-checkbox { display:flex; align-items:center; gap:8px; cursor:pointer; white-space:nowrap; }
  .for-contador { color:#6b7280; font-size:.9rem; white-space:nowrap; }

  .for-table { width:100%; border-collapse:collapse; background:#fff; border-radius:8px; overflow:hidden; font-size:.9rem; }
  .for-table th { background:#7c3aed; color:#fff; padding:11px; text-align:left; font-size:.78rem; letter-spacing:.5px; }
  .for-table td { padding:11px; border-bottom:1px solid #e5e7eb; vertical-align:middle; }
  .for-table tr:hover { background:#faf5ff; }
  .for-empty { text-align:center; padding:32px; color:#9ca3af; }

  .for-doc { font-family:monospace; font-size:.85rem; white-space:nowrap; }
  .for-col-acoes { white-space:nowrap; text-align:right; width:1%; }
  .for-tag-ativo { background:#d1fae5; color:#065f46; padding:3px 10px; border-radius:12px; font-size:.75rem; font-weight:600; }
  .for-tag-inativo { background:#fee2e2; color:#991b1b; padding:3px 10px; border-radius:12px; font-size:.75rem; font-weight:600; }
  .for-btn-acao { background:none; border:none; cursor:pointer; font-size:1.1rem; padding:4px 8px; border-radius:4px; display:inline-block; }
  .for-btn-acao:hover { background:#e5e7eb; }

  /* Modal */
  .for-modal { position:fixed; inset:0; background:rgba(0,0,0,.5); display:flex; align-items:center; justify-content:center; z-index:1000; }
  .for-modal[hidden] { display:none; }
  .for-modal-content { background:#fff; border-radius:12px; width:90%; max-width:780px; max-height:90vh; overflow-y:auto; }
  .for-modal-header { display:flex; justify-content:space-between; align-items:center; padding:20px; background:#7c3aed; color:#fff; border-radius:12px 12px 0 0; }
  .for-modal-header h2 { margin:0; font-size:1.2rem; }
  .for-close { background:none; border:none; color:#fff; font-size:1.8rem; cursor:pointer; }

  .for-form { padding:16px 24px 24px; }
  .for-form * { box-sizing:border-box; }
  .for-fieldset { border:1px solid #e5e7eb; border-radius:8px; padding:12px 16px; margin-bottom:14px; }
  .for-fieldset legend { padding:0 8px; font-weight:600; color:#374151; font-size:.9rem; }
  .for-fieldset[hidden] { display:none; }
  .for-row { display:flex; gap:12px; margin-bottom:10px; flex-wrap:wrap; }
  .flex-fix { flex:0 0 auto; }
  .flex-grow { flex:1; min-width:180px; }
  .for-form label { display:flex; flex-direction:column; gap:6px; }
  .for-form label span { font-size:.85rem; color:#374151; font-weight:500; }
  .for-form label em { color:#dc2626; font-style:normal; }
  .for-form input, .for-form select { width:100%; padding:9px 12px; border:1px solid #d1d5db; border-radius:7px; font-size:.92rem; transition:border-color .15s; }
  .for-form input:focus, .for-form select:focus { outline:none; border-color:#7c3aed; box-shadow:0 0 0 3px rgba(124,58,237,.1); }

  .input-wrap { display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
  .input-wrap input { flex:1 1 130px; min-width:130px; }
  .status-busca { font-size:.72rem; color:#6b7280; white-space:nowrap; }
  .status-busca.ok { color:#059669; }
  .status-busca.erro { color:#dc2626; }

  .preenchido { background:#fef9c3 !important; border-color:#facc15 !important; }
  .pendente { border-color:#fb923c !important; background:#fff7ed !important; }
  .for-erro-flash { animation:forShake .4s; border-color:#dc2626 !important; }
  @keyframes forShake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-5px)} 75%{transform:translateX(5px)} }

  /* IE/IM */
  .bloco-inscricoes { display:flex; gap:10px; }
  .campo-isento-wrap { display:flex; gap:6px; align-items:stretch; }
  .campo-isento-wrap input { flex:1; min-width:0; }
  .btn-isento { background:#f3f4f6; border:1px solid #d1d5db; border-radius:7px; padding:0 12px; font-size:.75rem; font-weight:600; color:#4b5563; cursor:pointer; white-space:nowrap; }
  .btn-isento:hover { background:#e5e7eb; }
  .btn-isento.ativo { background:#ecfccb; border-color:#84cc16; color:#4d7c0f; }

  /* Contatos especializados */
  .toggle-contatos { background:none; border:none; cursor:pointer; font-weight:600; color:#374151; font-size:.9rem; padding:0; }
  .contato-grupo { margin-bottom:12px; padding:10px; background:#faf5ff; border-radius:8px; }
  .contato-grupo h4 { margin:0 0 8px; font-size:.85rem; color:#6d28d9; }

  .for-modal-footer { display:flex; justify-content:flex-end; gap:12px; padding-top:14px; border-top:1px solid #e5e7eb; }
  .for-btn-cancel { background:#f3f4f6; border:1px solid #d1d5db; border-radius:7px; padding:9px 18px; cursor:pointer; font-weight:500; }
  .for-btn-salvar { background:#7c3aed; color:#fff; border:none; border-radius:7px; padding:9px 24px; font-weight:600; cursor:pointer; }
  .for-btn-salvar:hover { background:#6d28d9; }
</style>

<script src="/js/auxiliares/fornecedores.js"></script>
