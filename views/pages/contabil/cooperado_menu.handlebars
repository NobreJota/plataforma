    {{!-- Folhas de recebendo/pagando/lancamentos/pesquisa REMOVIDAS:
         agora o recebimento/pagamento é feito clicando na linha do
         Grid do Fluxo de Caixa (modal), não por menu. --}}

    <ul class="coop-leaf-list" data-leaf="pessoal">
      <li class="coop-sub-title">Pessoal</li>
      <li class="coop-leaf-item"><a href="/contabil/pessoal/cadastro">Cadastro</a></li>
      <li class="coop-leaf-item"><a href="/contabil/pessoal/alterar">Alterar</a></li>
      <li class="coop-leaf-item"><a href="/contabil/pessoal/deletar">Deletar</a></li>
    </ul>

  </div>

</div>

<style>
  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');

  .coop-menu-wrap {
    display: flex;
    min-height: 100vh;
    font-family: 'Segoe UI', sans-serif;
    font-size: 14px;
  }

  /* Sidebar principal */
  .coop-sidebar {
    width: 210px;
    background: #1e2a3a;
    color: #c8d6e5;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }
  .coop-sidebar-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 1.25rem 1rem;
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .coop-sidebar-header i { font-size: 20px; color: #4dabf7; }
  .coop-nav { list-style: none; padding: 0.5rem 0; margin: 0; }
  .coop-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 1rem;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all 0.15s;
    color: #a8bdd0;
  }
  .coop-nav-item:hover { background: rgba(255,255,255,0.07); color: #fff; }
  .coop-nav-item.active { background: rgba(77,171,247,0.15); color: #4dabf7; border-left-color: #4dabf7; }
  .coop-nav-item > i:first-child { font-size: 18px; }
  .coop-nav-item > span { flex: 1; }
  .coop-arrow { font-size: 13px; opacity: 0.5; }

  /* Coluna submenu nível 2 */
  .coop-sub-col {
    width: 210px;
    background: #f8f9fa;
    border-right: 1px solid #dee2e6;
    flex-shrink: 0;
    display: none;
  }
  .coop-sub-col.visible { display: block; }
  .coop-sub-list { list-style: none; padding: 0.75rem 0; margin: 0; display: none; }
  .coop-sub-list.visible { display: block; }
  .coop-sub-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #868e96;
    padding: 0 1rem 0.5rem;
  }
  .coop-sub-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 9px 1rem;
    cursor: pointer;
    color: #495057;
    border-left: 3px solid transparent;
    transition: all 0.12s;
  }
  .coop-sub-item:hover { background: #e9ecef; color: #212529; }
  .coop-sub-item.active { background: #e7f5ff; color: #1971c2; border-left-color: #1971c2; font-weight: 500; }
  .coop-sub-item i { font-size: 13px; opacity: 0.4; }

  /* Coluna folha nível 3 */
  .coop-leaf-col {
    width: 210px;
    background: #fff;
    border-right: 1px solid #dee2e6;
    flex-shrink: 0;
    display: none;
  }
  .coop-leaf-col.visible { display: block; }
  .coop-leaf-list { list-style: none; padding: 0.75rem 0; margin: 0; display: none; }
  .coop-leaf-list.visible { display: block; }
  .coop-leaf-item { padding: 0; }
  .coop-leaf-item a {
    display: block;
    padding: 8px 1rem;
    color: #495057;
    text-decoration: none;
    font-size: 13px;
    transition: all 0.12s;
    border-left: 3px solid transparent;
  }
  .coop-leaf-item a:hover { background: #f1f3f5; color: #1971c2; border-left-color: #1971c2; }
</style>

<script>
(function () {
  const navItems   = document.querySelectorAll('.coop-nav-item');
  const subPanel   = document.getElementById('coop-sub-panel');
  const leafPanel  = document.getElementById('coop-leaf-panel');
  const subLists   = document.querySelectorAll('.coop-sub-list');
  const leafLists  = document.querySelectorAll('.coop-leaf-list');
  const subItems   = document.querySelectorAll('.coop-sub-item');

  function hideLeaf() {
    leafPanel.classList.remove('visible');
    leafLists.forEach(l => l.classList.remove('visible'));
    subItems.forEach(i => i.classList.remove('active'));
  }

  navItems.forEach(function (item) {
    item.addEventListener('click', function () {
      const key = this.dataset.menu;
      navItems.forEach(i => i.classList.remove('active'));
      this.classList.add('active');
      subLists.forEach(l => l.classList.remove('visible'));
      hideLeaf();
      const target = document.querySelector('.coop-sub-list[data-sub="' + key + '"]');
      if (target) {
        subPanel.classList.add('visible');
        target.classList.add('visible');
      } else {
        subPanel.classList.remove('visible');
      }
    });
  });

  subItems.forEach(function (item) {
    item.addEventListener('click', function () {
      const leafKey = this.dataset.leaf;
      const url     = this.dataset.url;
      subItems.forEach(i => i.classList.remove('active'));
      this.classList.add('active');
      leafLists.forEach(l => l.classList.remove('visible'));
      if (leafKey) {
        const target = document.querySelector('.coop-leaf-list[data-leaf="' + leafKey + '"]');
        if (target) {
          leafPanel.classList.add('visible');
          target.classList.add('visible');
          return;
        }
      }
      leafPanel.classList.remove('visible');
      if (url) window.location.href = url;
    });
  });
})();
</script>
