<div class="cmp-page">
  <header class="cmp-header">
    <h1>🛒 Programação de Compras</h1>
    <div class="cmp-controls">
      <label class="cmp-ano-label">Ano:
        <select id="cmp-ano" class="cmp-ano-select"></select>
      </label>
      <button class="cmp-btn-vincular" id="btn-vincular">🔗 Vincular fornecedores</button>
    </div>
  </header>

  <div class="cmp-grid-wrap">
    <table class="cmp-grid" id="grid">
      <thead>
        <tr>
          <th class="col-item">#</th>
          <th class="col-forn">Fornecedor</th>
          <th>Jan</th><th>Fev</th><th>Mar</th><th>Abr</th><th>Mai</th><th>Jun</th>
          <th>Jul</th><th>Ago</th><th>Set</th><th>Out</th><th>Nov</th><th>Dez</th>
          <th class="col-total">Total</th>
        </tr>
      </thead>
      <tbody id="grid-body">
        <tr><td colspan="15" class="cmp-empty">Carregando...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal vincular fornecedores -->
<div id="modal-vincular" class="cmp-modal" hidden>
  <div class="cmp-modal-content">
    <div class="cmp-modal-header">
      <h2>🔗 Vincular fornecedores à programação</h2>
      <button class="cmp-close" id="btn-fechar-vincular">×</button>
    </div>
    <div class="cmp-modal-body">
      <p class="cmp-hint">Marque os fornecedores que entram na programação de compras.
        A vinculação vale para todos os anos. Desmarcar um fornecedor o desativa
        (some do grid) sem apagar o histórico.</p>
      <input type="search" id="busca-forn" class="cmp-busca" placeholder="🔍 Buscar por razão, CNPJ ou marca...">
      <div class="cmp-lista-vincular" id="lista-vincular">
        <p class="cmp-empty">Carregando fornecedores...</p>
      </div>
    </div>
    <div class="cmp-modal-footer">
      <span id="contador-vinc" class="cmp-contador-vinc"></span>
      <button type="button" id="btn-cancelar-vincular" class="cmp-btn-cancel">Cancelar</button>
      <button type="button" id="btn-salvar-vincular" class="cmp-btn-salvar">Salvar vinculação</button>
    </div>
  </div>
</div>

<!-- Modal de lançamento -->
<div id="modal-lancamento" class="cmp-modal" hidden>
  <div class="cmp-modal-content cmp-modal-lanc">
    <div class="cmp-modal-header">
      <h2 id="lanc-titulo">Lançamento de compra projetada</h2>
      <button class="cmp-close" id="btn-fechar-lanc">×</button>
    </div>
    <div class="cmp-modal-body">
      <div class="lanc-info">
        <span id="lanc-razao" class="lanc-razao"></span>
        <span id="lanc-ano" class="lanc-ano"></span>
      </div>

      <div class="lanc-form">
        <div class="lanc-row">
          <label class="lanc-grow">
            <span>Histórico</span>
            <input type="text" id="lanc-historico" placeholder="Descrição da compra projetada">
          </label>
        </div>
        <div class="lanc-row">
          <label class="lanc-fix" style="min-width:140px">
            <span>Valor (R$)</span>
            <input type="text" id="lanc-valor" inputmode="decimal" placeholder="0,00">
          </label>
          <label class="lanc-fix" style="min-width:160px">
            <span>Tipo do valor</span>
            <select id="lanc-modo">
              <option value="parcela">Por parcela</option>
              <option value="total">Valor total</option>
            </select>
          </label>
          <label class="lanc-fix" style="min-width:100px">
            <span>Parcelas</span>
            <input type="number" id="lanc-parcelas" min="1" max="48" value="1">
          </label>
          <label class="lanc-fix" style="min-width:150px">
            <span>Frequência</span>
            <select id="lanc-frequencia">
              <option value="1">Mensal</option>
              <option value="2">Bimensal (2/2)</option>
              <option value="3">Trimestral (3/3)</option>
              <option value="4">Quadrimestral</option>
              <option value="6">Semestral</option>
            </select>
          </label>
        </div>
        <div class="lanc-row">
          <label class="lanc-fix" style="min-width:150px">
            <span>Mês inicial</span>
            <select id="lanc-mes-inicial">
              <option value="1">Janeiro</option><option value="2">Fevereiro</option>
              <option value="3">Março</option><option value="4">Abril</option>
              <option value="5">Maio</option><option value="6">Junho</option>
              <option value="7">Julho</option><option value="8">Agosto</option>
              <option value="9">Setembro</option><option value="10">Outubro</option>
              <option value="11">Novembro</option><option value="12">Dezembro</option>
            </select>
          </label>
          <label class="lanc-fix" style="min-width:120px">
            <span>Dia vencimento</span>
            <input type="number" id="lanc-dia" min="1" max="31" value="10">
          </label>
          <button type="button" id="btn-add-lancamento" class="lanc-btn-add">+ Adicionar</button>
        </div>
      </div>

      <div class="lanc-preview" id="lanc-preview" hidden>
        <h4>Pré-visualização das parcelas</h4>
        <div class="lanc-preview-lista" id="lanc-preview-lista"></div>
        <div class="lanc-preview-total" id="lanc-preview-total"></div>
      </div>

      <div class="lanc-salvos">
        <h4>Compras projetadas deste fornecedor no ano</h4>
        <div id="lanc-salvos-lista" class="lanc-salvos-lista">
          <p class="cmp-empty">Nenhum lançamento ainda.</p>
        </div>
      </div>
    </div>
    <div class="cmp-modal-footer">
      <span class="lanc-rodape-info">As parcelas alimentam o Fluxo Projetado como compras futuras (pos 7).</span>
      <button type="button" id="btn-fechar-lanc-rodape" class="cmp-btn-cancel">Fechar</button>
    </div>
  </div>
</div>

<style>
  .cmp-page { padding:20px; max-width:1500px; margin:0 auto; }
  .cmp-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; flex-wrap:wrap; gap:12px; }
  .cmp-header h1 { margin:0; font-size:1.5rem; }
  .cmp-controls { display:flex; align-items:center; gap:14px; }
  .cmp-ano-label { display:flex; align-items:center; gap:8px; font-weight:600; color:#374151; }
  .cmp-ano-select { padding:8px 12px; border:1px solid #d1d5db; border-radius:7px; font-size:1rem; font-weight:600; }
  .cmp-btn-vincular { background:#d97706; color:#fff; border:none; border-radius:8px; padding:10px 18px; font-weight:600; cursor:pointer; }
  .cmp-btn-vincular:hover { background:#b45309; }

  .cmp-grid-wrap { overflow-x:auto; border:1px solid #d1d5db; border-radius:8px; background:#fff; }
  .cmp-grid { width:100%; border-collapse:collapse; font-size:.84rem; }
  .cmp-grid th { background:#fef3c7; color:#92400e; padding:8px 10px; text-align:right; font-size:.74rem; border-bottom:2px solid #fcd34d; white-space:nowrap; position:sticky; top:0; }
  .cmp-grid th.col-item { text-align:center; width:36px; }
  .cmp-grid th.col-forn { text-align:left; min-width:200px; }
  .cmp-grid th.col-total { text-align:right; background:#fde68a; border-left:2px solid #fcd34d; }
  .cmp-grid td { padding:6px 10px; border-bottom:1px solid #f0f0f0; text-align:right; white-space:nowrap; }
  .cmp-grid td.cel-item { text-align:center; color:#9ca3af; font-size:.75rem; }
  .cmp-grid td.cel-forn { text-align:left; cursor:pointer; color:#1f2937; }
  .cmp-grid td.cel-forn:hover { color:#d97706; text-decoration:underline; }
  .cmp-conta-row:hover { background:#fffbeb; }

  .cel-valor { cursor:pointer; font-variant-numeric:tabular-nums; }
  .cel-valor:hover { background:#fef3c7; border-radius:4px; }
  .cel-valor.tem-valor { color:#b45309; font-weight:600; }
  .cel-valor.vazio { color:#e5e7eb; }
  .cel-total { font-weight:700; color:#92400e; background:#fffbeb; border-left:2px solid #fcd34d; }

  /* Linha de totais (rodapé) */
  .cmp-totais-row td { background:#92400e; color:#fff; font-weight:700; padding:10px; text-align:right; border-top:2px solid #78350f; position:sticky; bottom:0; font-variant-numeric:tabular-nums; }
  .cmp-totais-row .cel-total-label { text-align:left; font-size:.8rem; letter-spacing:.5px; }
  .cmp-totais-row .cel-total-mes { font-size:.82rem; }
  .cmp-totais-row .cel-total-geral { background:#78350f; border-left:2px solid #fcd34d; font-size:.9rem; }

  .cmp-empty { text-align:center; padding:32px; color:#9ca3af; }

  /* Modal (compartilha estilo) */
  .cmp-modal { position:fixed; inset:0; background:rgba(0,0,0,.5); display:flex; align-items:center; justify-content:center; z-index:1000; }
  .cmp-modal[hidden] { display:none; }
  .cmp-modal-content { background:#fff; border-radius:12px; width:90%; max-width:640px; max-height:85vh; display:flex; flex-direction:column; }
  .cmp-modal-lanc { max-width:680px; }
  .cmp-modal-header { display:flex; justify-content:space-between; align-items:center; padding:18px 20px; background:#d97706; color:#fff; border-radius:12px 12px 0 0; }
  .cmp-modal-header h2 { margin:0; font-size:1.15rem; }
  .cmp-close { background:none; border:none; color:#fff; font-size:1.6rem; cursor:pointer; }
  .cmp-modal-body { padding:18px 20px; overflow-y:auto; flex:1; }
  .cmp-hint { font-size:.82rem; color:#6b7280; margin:0 0 12px; line-height:1.4; }
  .cmp-busca { width:100%; padding:9px 12px; border:1px solid #d1d5db; border-radius:7px; margin-bottom:12px; box-sizing:border-box; }

  .cmp-lista-vincular { display:flex; flex-direction:column; gap:2px; }
  .cmp-item-vinc { display:flex; align-items:center; gap:10px; padding:7px 8px; border-radius:6px; cursor:pointer; }
  .cmp-item-vinc:hover { background:#fffbeb; }
  .cmp-item-vinc input { width:17px; height:17px; cursor:pointer; }
  .cmp-item-vinc .razao { flex:1; font-size:.88rem; color:#1f2937; }
  .cmp-item-vinc .cnpj { font-family:monospace; font-size:.76rem; color:#6b7280; }
  .cmp-item-vinc .marca { font-size:.76rem; color:#92400e; background:#fef3c7; padding:1px 6px; border-radius:4px; }

  .cmp-modal-footer { display:flex; align-items:center; gap:12px; padding:14px 20px; border-top:1px solid #e5e7eb; }
  .cmp-contador-vinc { flex:1; font-size:.82rem; color:#6b7280; }
  .cmp-btn-cancel { background:#f3f4f6; border:1px solid #d1d5db; border-radius:7px; padding:9px 18px; cursor:pointer; font-weight:500; }
  .cmp-btn-salvar { background:#d97706; color:#fff; border:none; border-radius:7px; padding:9px 22px; font-weight:600; cursor:pointer; }
  .cmp-btn-salvar:hover { background:#b45309; }

  /* Modal lançamento */
  .lanc-info { display:flex; gap:12px; align-items:center; padding:10px 12px; background:#fffbeb; border-radius:8px; margin-bottom:14px; }
  .lanc-razao { font-weight:700; color:#1f2937; flex:1; }
  .lanc-ano { color:#6b7280; font-size:.9rem; }
  .lanc-form { background:#fafafa; border:1px solid #e5e7eb; border-radius:8px; padding:14px; margin-bottom:14px; }
  .lanc-row { display:flex; gap:10px; margin-bottom:10px; flex-wrap:wrap; align-items:flex-end; }
  .lanc-row:last-child { margin-bottom:0; }
  .lanc-grow { flex:1; min-width:180px; }
  .lanc-fix { flex:0 0 auto; }
  .lanc-form label { display:flex; flex-direction:column; gap:5px; }
  .lanc-form label span { font-size:.8rem; color:#374151; font-weight:500; }
  .lanc-form input, .lanc-form select { padding:8px 10px; border:1px solid #d1d5db; border-radius:7px; font-size:.9rem; box-sizing:border-box; }
  .lanc-form input:focus, .lanc-form select:focus { outline:none; border-color:#d97706; box-shadow:0 0 0 3px rgba(217,119,6,.1); }
  .lanc-btn-add { background:#d97706; color:#fff; border:none; border-radius:7px; padding:9px 18px; font-weight:600; cursor:pointer; height:38px; }
  .lanc-btn-add:hover { background:#b45309; }

  .lanc-preview { background:#fffbeb; border:1px solid #fcd34d; border-radius:8px; padding:12px; margin-bottom:14px; }
  .lanc-preview h4 { margin:0 0 8px; font-size:.85rem; color:#92400e; }
  .lanc-preview-lista { display:flex; flex-direction:column; gap:3px; max-height:160px; overflow-y:auto; font-size:.82rem; }
  .lanc-preview-item { display:flex; justify-content:space-between; padding:3px 6px; }
  .lanc-preview-item:nth-child(even) { background:rgba(255,255,255,.5); }
  .lanc-preview-total { margin-top:8px; padding-top:8px; border-top:1px solid #fcd34d; font-weight:700; color:#92400e; text-align:right; }

  .lanc-salvos h4 { margin:0 0 8px; font-size:.85rem; color:#374151; }
  .lanc-salvos-lista { display:flex; flex-direction:column; gap:6px; }
  .lanc-salvo-item { display:flex; align-items:center; gap:10px; padding:8px 10px; background:#f9fafb; border:1px solid #e5e7eb; border-radius:7px; font-size:.85rem; }
  .lanc-salvo-desc { flex:1; }
  .lanc-salvo-valor { font-weight:600; color:#92400e; }
  .lanc-btn-edit, .lanc-btn-del { background:none; border:none; cursor:pointer; font-size:1rem; padding:3px 6px; border-radius:4px; }
  .lanc-btn-edit:hover { background:#fef3c7; }
  .lanc-btn-del:hover { background:#fee2e2; }
  .lanc-rodape-info { flex:1; font-size:.78rem; color:#6b7280; }
</style>

<script src="/js/financeiro/compras.js"></script>
